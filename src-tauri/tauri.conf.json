{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yebot",
  "version": "0.1.0",
  "identifier": "fr.ye.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "",
      "endpoints": [
        "https://github.com/cpasneedles/ye_installer/releases/latest/download/update.json"
      ],
      "dialog": true,
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "enableGTKAppId": true,
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    },
    "windows": [
      {
        "title": "ye",
        "minWidth": 1200,
        "minHeight": 700,
        "decorations": false
      }
    ],
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}